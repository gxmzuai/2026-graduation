---
import Ornament from './Ornament.astro';
import { NAV, SITE } from '@/data/site';

const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="site-nav" data-nav>
  <div class="shell flex h-16 items-center justify-between gap-4 md:h-[4.5rem]">
    <a href="/" class="group flex items-center gap-2.5" aria-label={`${SITE.school} 2026 届首页`}>
      <Ornament variant="flower" class="size-7 text-gold transition-transform duration-700 group-hover:rotate-45" />
      <span class="flex flex-col leading-none">
        <span class="font-serif text-base font-semibold tracking-wide text-cream">广西民大 · 2026</span>
        <span class="mt-0.5 text-[0.62rem] uppercase tracking-[0.3em] text-gold/70">Class of 2026</span>
      </span>
    </a>

    <!-- 桌面导航 -->
    <nav class="nav-desktop" aria-label="主导航">
      {
        NAV.map((link) => (
          <a
            href={link.href}
            class:list={['nav-link', isActive(link.href) && 'is-active']}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- 移动端开关 -->
    <button
      type="button"
      class="nav-toggle"
      data-nav-toggle
      aria-label="打开菜单"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- 移动端面板 -->
  <nav id="mobile-nav" class="mobile-nav" data-mobile-nav aria-label="移动导航" hidden>
    <div class="shell flex flex-col gap-1 py-4">
      {
        NAV.map((link) => (
          <a
            href={link.href}
            class:list={['mobile-link', isActive(link.href) && 'is-active']}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            <span class="font-serif text-lg">{link.label}</span>
            <span class="text-[0.7rem] uppercase tracking-[0.25em] text-gold/60">{link.en}</span>
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  // 导航在每次客户端路由后会重新渲染（用于更新当前页高亮），因此元素绑定要在
  // astro:page-load 时对新节点重做；而 window 级监听（滚动、Esc）只注册一次，
  // 通过可变引用指向当前导航节点，避免每次翻页累积重复监听。
  let header: HTMLElement | null = null;
  let toggle: HTMLButtonElement | null = null;
  let panel: HTMLElement | null = null;

  const setOpen = (open: boolean) => {
    if (!header || !toggle || !panel) return;
    header.classList.toggle('is-open', open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? '关闭菜单' : '打开菜单');
    if (open) panel.hidden = false;
    else {
      const p = panel;
      setTimeout(() => {
        if (header && !header.classList.contains('is-open')) p.hidden = true;
      }, 260);
    }
  };

  const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 24);

  // 只注册一次
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });

  const setupNav = () => {
    header = document.querySelector<HTMLElement>('[data-nav]');
    toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
    panel = document.querySelector<HTMLElement>('[data-mobile-nav]');
    if (!header || !toggle || !panel) return;

    toggle.addEventListener('click', () =>
      setOpen(toggle!.getAttribute('aria-expanded') !== 'true'),
    );
    panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    onScroll(); // 进入新页面后按当前滚动位置即时校正底色
  };

  document.addEventListener('astro:page-load', setupNav);
</script>

<style>
  .site-nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    border-bottom: 1px solid transparent;
    transition: background-color 0.4s var(--ease-out-soft), border-color 0.4s,
      backdrop-filter 0.4s;
  }
  .site-nav.is-scrolled,
  .site-nav.is-open {
    background-color: oklch(0.185 0.012 172 / 0.82);
    backdrop-filter: blur(14px) saturate(1.4);
    border-bottom-color: var(--color-line);
  }

  /* 响应式显隐用作用域媒体查询控制（避免 [data-astro-cid] 优先级压过 Tailwind 的 md: 工具类）。
     真正的 @media 覆盖块放在样式表末尾——见文件底部，确保按源码顺序胜过下面的 .nav-toggle 基础规则。 */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    position: relative;
    padding: 0.5rem 0.95rem;
    font-size: 0.95rem;
    color: var(--color-mist);
    border-radius: 999px;
    transition: color 0.25s;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0.28rem;
    height: 1.5px;
    width: 0;
    translate: -50% 0;
    background: var(--color-gold);
    transition: width 0.3s var(--ease-out-soft);
  }
  .nav-link:hover {
    color: var(--color-cream);
  }
  .nav-link:hover::after {
    width: 1.1rem;
  }
  .nav-link.is-active {
    color: var(--color-gold);
  }
  .nav-link.is-active::after {
    width: 1.1rem;
  }

  .nav-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0 0.6rem;
    border-radius: 0.75rem;
  }
  .nav-toggle span {
    display: block;
    height: 1.6px;
    width: 100%;
    background: var(--color-cream);
    transition: transform 0.3s var(--ease-out-soft), opacity 0.2s;
  }
  .site-nav.is-open .nav-toggle span:nth-child(1) {
    transform: translateY(6.6px) rotate(45deg);
  }
  .site-nav.is-open .nav-toggle span:nth-child(2) {
    opacity: 0;
  }
  .site-nav.is-open .nav-toggle span:nth-child(3) {
    transform: translateY(-6.6px) rotate(-45deg);
  }

  .mobile-nav {
    overflow: hidden;
    max-height: 0;
    border-bottom: 1px solid transparent;
    background-color: oklch(0.185 0.012 172 / 0.94);
    backdrop-filter: blur(14px);
    transition: max-height 0.32s var(--ease-out-soft), border-color 0.32s;
  }
  .site-nav.is-open .mobile-nav {
    max-height: 22rem;
    border-bottom-color: var(--color-line);
  }
  .mobile-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 0.85rem 0.5rem;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-mist);
  }
  .mobile-link:last-child {
    border-bottom: none;
  }
  .mobile-link.is-active {
    color: var(--color-gold);
  }

  /* 桌面端（≥768px）显隐覆盖：必须放在所有基础规则之后。
     同优先级（均为 .foo[data-astro-cid]）下后写者胜——此前该块写在 .nav-toggle 基础规则之前，
     导致 .nav-toggle{display:inline-flex} 反压过媒体查询里的 display:none，桌面端仍显示汉堡按钮。 */
  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
    .nav-toggle,
    .mobile-nav {
      display: none;
    }
  }
</style>
