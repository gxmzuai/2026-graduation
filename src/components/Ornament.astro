---
/**
 * 点缀图案：
 *  - flower  朱槿花（南宁市花）五瓣花型，作徽记 / logo
 *  - band    壮锦菱形织带，作分割线
 *  - diamond 单枚壮锦菱花，作小点缀
 * 颜色继承 currentColor，用 text-* / opacity 控制即可。
 */
interface Props {
  variant?: 'flower' | 'band' | 'diamond';
  class?: string;
}
const { variant = 'flower', class: className = '' } = Astro.props;

const C = 50;
// 一片花瓣（朝上，自花心 50,50 伸出到 50,8 的水滴形）
const PETAL = 'M50 50 C 33 42, 28 22, 50 8 C 72 22, 67 42, 50 50 Z';
const petals = [0, 72, 144, 216, 288];
// 花蕊小点（环绕花心）
const anthers = Array.from({ length: 6 }, (_, i) => {
  const a = (i / 6) * Math.PI * 2 - Math.PI / 2;
  return [+(C + Math.cos(a) * 9).toFixed(2), +(C + Math.sin(a) * 9).toFixed(2)];
});
---

{
  variant === 'flower' && (
    <svg viewBox="0 0 100 100" fill="none" aria-hidden="true" class={className}>
      {petals.map((deg) => (
        <path
          d={PETAL}
          transform={`rotate(${deg} 50 50)`}
          fill="currentColor"
          fill-opacity="0.13"
          stroke="currentColor"
          stroke-width="1.2"
          stroke-opacity="0.92"
          stroke-linejoin="round"
        />
      ))}
      {anthers.map(([x, y]) => (
        <circle cx={x} cy={y} r="1.5" fill="currentColor" opacity="0.85" />
      ))}
      <circle cx="50" cy="50" r="4.6" fill="currentColor" />
    </svg>
  )
}

{
  variant === 'band' && (
    <svg
      viewBox="0 0 120 16"
      preserveAspectRatio="xMidYMid meet"
      fill="none"
      aria-hidden="true"
      class={className}
      stroke="currentColor"
    >
      <defs>
        <pattern id="zj-band" width="20" height="16" patternUnits="userSpaceOnUse">
          <path d="M10 1.5L18.5 8 10 14.5 1.5 8Z" stroke-width="0.9" opacity="0.85" />
          <path d="M10 5L13 8 10 11 7 8Z" fill="currentColor" stroke="none" opacity="0.9" />
          <path d="M0 8H1.5M18.5 8H20" stroke-width="0.9" opacity="0.5" />
        </pattern>
      </defs>
      <rect width="120" height="16" fill="url(#zj-band)" />
    </svg>
  )
}

{
  variant === 'diamond' && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
      class={className}
      stroke="currentColor"
    >
      <path d="M12 1L23 12 12 23 1 12Z" stroke-width="1" opacity="0.8" />
      <path d="M12 6L18 12 12 18 6 12Z" stroke-width="0.8" opacity="0.5" />
      <path d="M12 10L14 12 12 14 10 12Z" fill="currentColor" stroke="none" />
    </svg>
  )
}
