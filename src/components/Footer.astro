---
import Ornament from './Ornament.astro';
import { SITE, NAV } from '@/data/site';

// 版权年份取在校区间（2023 — 2026），与 journey 同源，毕业纪念册固定不随当前年漂移
const copyStart = SITE.startDate.slice(0, 4);
const copyEnd = SITE.endDate.slice(0, 4);
const span = copyStart === copyEnd ? copyStart : `${copyStart} — ${copyEnd}`;
const journey = `${SITE.startDate.replaceAll('-', '.')} — ${SITE.endDate.replaceAll('-', '.')}`;
---

<footer class="relative mt-32 overflow-hidden border-t border-line/70 vignette">
  <div class="shell pb-8 pt-16">
    <div class="flex flex-col items-center gap-7 text-center">
      <Ornament variant="flower" class="size-10 text-gold/80" />

      <p class="max-w-md text-pretty font-serif text-lg leading-relaxed text-cream/90">
        谨以此册，纪念我们在{SITE.school}相思湖畔
        <br class="hidden sm:block" />共同走过的青春。
      </p>

      <Ornament variant="band" class="h-3.5 w-52 text-gold/45" />

      <p class="font-display text-sm tracking-[0.25em] text-gold/75">{journey}</p>

      <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2" aria-label="页脚导航">
        {
          NAV.map((link) => (
            <a href={link.href} class="inline-block px-1 py-2 text-sm text-mist transition-colors hover:text-gold">
              {link.label}
            </a>
          ))
        }
      </nav>

      <div class="mt-2 space-y-1.5 text-xs text-faint">
        <p class="tracking-wide">{SITE.school} · {SITE.schoolEn}</p>
        <p>© {span} · Made with <span class="text-cinnabar">❤</span> by {SITE.author}</p>
        <p>
          <a
            href={SITE.repo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-faint transition-colors hover:text-gold"
          >
            <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="size-3.5">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
              />
            </svg>
            <span>源码 · Source</span>
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>
