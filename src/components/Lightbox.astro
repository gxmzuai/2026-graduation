---
import type { GalleryPhoto } from '@/data/gallery';

interface Props {
  photos: GalleryPhoto[];
}
const { photos } = Astro.props;
---

<dialog class="lightbox" data-lightbox aria-label="照片预览">
  <button class="lb-btn lb-close" data-lb-close type="button" aria-label="关闭 (Esc)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
    </svg>
  </button>

  <button class="lb-btn lb-prev" data-lb-prev type="button" aria-label="上一张 (←)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M15 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>
  <button class="lb-btn lb-next" data-lb-next type="button" aria-label="下一张 (→)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>

  <div class="lb-stage" data-lb-stage>
    {
      photos.map((p, i) => (
        <figure
          class="lb-slide"
          data-lb-slide={i}
          data-title={p.title}
          data-desc={p.description}
          data-date={p.date}
          hidden={i !== 0}
        >
          <img
            src={p.url}
            alt={p.title}
            class="lb-img"
            loading="lazy"
            decoding="async"
            referrerpolicy="no-referrer"
          />
        </figure>
      ))
    }
  </div>

  <div class="lb-caption" data-lb-caption role="group" aria-live="polite">
    <div class="lb-caption__main">
      <span class="lb-caption__index" data-lb-count></span>
      <h3 class="lb-caption__title font-serif" data-lb-title></h3>
    </div>
    <p class="lb-caption__desc" data-lb-desc></p>
    <p class="lb-caption__date" data-lb-date></p>
  </div>
</dialog>

<script>
  // 灯箱与缩略图触发器都属于画廊页内容，视图过渡后会换成新节点，
  // 因此元素绑定在 astro:page-load 时对新节点重做；window 键盘监听只注册一次，
  // 通过模块级引用 lb 指向当前灯箱，避免反复进入画廊页时累积重复监听。
  type LB = { dialog: HTMLDialogElement; prev: () => void; next: () => void };
  let lb: LB | null = null;

  window.addEventListener('keydown', (e) => {
    if (!lb || !lb.dialog.open) return;
    if (e.key === 'ArrowLeft') lb.prev();
    else if (e.key === 'ArrowRight') lb.next();
  });

  const setupLightbox = () => {
    const dialog = document.querySelector<HTMLDialogElement>('[data-lightbox]');
    if (!dialog) {
      lb = null; // 离开画廊页：解除引用，键盘监听随之空跑
      return;
    }
    const slides = Array.from(dialog.querySelectorAll<HTMLElement>('[data-lb-slide]'));
    const total = slides.length;
    const elTitle = dialog.querySelector<HTMLElement>('[data-lb-title]');
    const elDesc = dialog.querySelector<HTMLElement>('[data-lb-desc]');
    const elDate = dialog.querySelector<HTMLElement>('[data-lb-date]');
    const elCount = dialog.querySelector<HTMLElement>('[data-lb-count]');
    let current = 0;

    const render = (i: number) => {
      if (!total) return;
      current = (i + total) % total;
      slides.forEach((s, idx) => {
        s.hidden = idx !== current;
      });
      const s = slides[current];
      if (elTitle) elTitle.textContent = s.dataset.title ?? '';
      if (elDesc) {
        elDesc.textContent = s.dataset.desc ?? '';
        elDesc.hidden = !s.dataset.desc;
      }
      if (elDate) elDate.textContent = s.dataset.date ?? '';
      if (elCount) elCount.textContent = `${current + 1} / ${total}`;
    };

    const open = (i: number) => {
      render(i);
      if (!dialog.open) dialog.showModal();
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      if (dialog.open) dialog.close();
    };

    // 缩略图触发
    document.querySelectorAll<HTMLElement>('[data-lightbox-open]').forEach((trigger) => {
      trigger.addEventListener('click', () => open(Number(trigger.dataset.lightboxOpen)));
    });

    dialog.querySelector('[data-lb-close]')?.addEventListener('click', close);
    dialog.querySelector('[data-lb-prev]')?.addEventListener('click', () => render(current - 1));
    dialog.querySelector('[data-lb-next]')?.addEventListener('click', () => render(current + 1));

    // 点击背景（stage 之外）关闭
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) close();
    });
    dialog.addEventListener('close', () => {
      document.body.style.overflow = '';
    });

    // 移动端左右滑动切换
    const stage = dialog.querySelector<HTMLElement>('[data-lb-stage]');
    let startX = 0;
    stage?.addEventListener(
      'touchstart',
      (e) => {
        startX = e.changedTouches[0].clientX;
      },
      { passive: true },
    );
    stage?.addEventListener(
      'touchend',
      (e) => {
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 40) render(dx < 0 ? current + 1 : current - 1);
      },
      { passive: true },
    );

    lb = { dialog, prev: () => render(current - 1), next: () => render(current + 1) };
  };

  document.addEventListener('astro:page-load', setupLightbox);
</script>

<style>
  .lightbox {
    width: 100vw;
    max-width: 100vw;
    height: 100dvh;
    max-height: 100dvh;
    margin: 0;
    padding: 0;
    border: none;
    background: oklch(0.12 0.012 168 / 0.97);
    color: var(--color-cream);
    overflow: hidden;
  }
  .lightbox::backdrop {
    background: oklch(0.08 0.01 168 / 0.8);
    backdrop-filter: blur(6px);
  }
  .lightbox[open] {
    animation: lb-in 0.32s var(--ease-out-soft);
  }
  @keyframes lb-in {
    from {
      opacity: 0;
    }
  }

  .lb-stage {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: clamp(1rem, 4vw, 3rem);
    padding-bottom: clamp(6rem, 16vh, 9rem);
  }
  .lb-slide {
    margin: 0;
    display: grid;
    place-items: center;
    max-width: 100%;
    max-height: 100%;
  }
  .lb-slide[hidden] {
    display: none;
  }
  .lb-img {
    width: auto;
    height: auto;
    max-width: min(92vw, 1600px);
    /* 以舞台内边距盒为界（顶部+底部 padding 至多 12rem），短横屏下也不溢出/压住说明 */
    max-height: min(80dvh, calc(100dvh - 12rem));
    object-fit: contain;
    border-radius: 0.4rem;
    box-shadow: 0 30px 80px -20px oklch(0 0 0 / 0.8);
    animation: lb-img-in 0.4s var(--ease-out-soft);
  }
  @keyframes lb-img-in {
    from {
      opacity: 0;
      transform: scale(0.985);
    }
  }

  .lb-btn {
    position: fixed;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    color: var(--color-cream);
    border-radius: 999px;
    background: oklch(0.2 0.012 168 / 0.6);
    border: 1px solid var(--color-line);
    transition: background-color 0.25s, color 0.25s, transform 0.25s;
  }
  .lb-btn svg {
    width: 1.5rem;
    height: 1.5rem;
  }
  .lb-btn:hover {
    background: var(--color-gold);
    color: var(--color-ink);
  }
  .lb-close {
    top: 1.1rem;
    right: 1.1rem;
  }
  .lb-prev {
    left: 1.1rem;
    top: 50%;
    transform: translateY(-50%);
  }
  .lb-next {
    right: 1.1rem;
    top: 50%;
    transform: translateY(-50%);
  }
  .lb-prev:hover {
    transform: translateY(-50%) scale(1.06);
  }
  .lb-next:hover {
    transform: translateY(-50%) scale(1.06);
  }

  .lb-caption {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3; /* 说明文字始终压过翻页按钮，避免被遮挡 */
    padding: 2.5rem clamp(1.25rem, 5vw, 3rem) 1.6rem;
    text-align: center;
    background: linear-gradient(to top, oklch(0.1 0.01 168 / 0.92), transparent);
  }
  .lb-caption__main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }
  .lb-caption__index {
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    color: var(--color-gold);
  }
  .lb-caption__title {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-cream);
  }
  .lb-caption__desc {
    margin: 0.4rem auto 0;
    max-width: 38rem;
    font-size: 0.95rem;
    color: var(--color-mist);
  }
  .lb-caption__date {
    margin-top: 0.5rem;
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    color: var(--color-faint);
  }

  @media (max-width: 640px) {
    .lb-btn {
      width: 2.6rem;
      height: 2.6rem;
    }
    /* 把左右翻页钮移到底部角落（说明文字上方），不再压住居中图片的边缘 */
    .lb-prev,
    .lb-next {
      top: auto;
      bottom: 8.5rem;
      transform: none;
    }
    .lb-prev {
      left: 0.75rem;
    }
    .lb-next {
      right: 0.75rem;
    }
    .lb-prev:hover,
    .lb-next:hover {
      transform: scale(1.06);
    }
  }
</style>
